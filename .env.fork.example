# [FORK] Environment configuration for Orion IDE / VS Code fork
# Copy this to the project root and fill in values before building

# Agent Manager: URL of the running Next.js companion app
# Leave empty to fall back to the bundled standalone HTML
AGENT_MANAGER_URL=

# Terminal WebSocket bridge port (default: 3002)
# The companion Next.js app should connect ws://localhost:FORK_TERMINAL_WS_PORT
FORK_TERMINAL_WS_PORT=3002

# Companion backend base URL (for AI proxy, agent chat, etc.)
FORK_BACKEND_URL=http://localhost:3001
